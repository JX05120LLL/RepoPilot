# Chat：Kimi K3（OpenAI-compatible）
REPOPILOT_CHAT_BASE_URL=https://api.deepseek.com
REPOPILOT_CHAT_API_KEY=
REPOPILOT_CHAT_MODEL=deepseek-v4-pro
# 可选：只有供应商真实返回 usage 时才会估算费用；单位为每 1,000,000 Token。
REPOPILOT_CHAT_INPUT_PRICE_PER_MILLION=
REPOPILOT_CHAT_OUTPUT_PRICE_PER_MILLION=
REPOPILOT_CHAT_PRICE_CURRENCY=CNY
# 可选：企业级任务预算。设置后会在每次模型调用后校验并持久化，未回传用量/成本时停止继续调用。
REPOPILOT_TASK_MAX_TOTAL_TOKENS=
REPOPILOT_TASK_MAX_ESTIMATED_COST=

# Embedding：阿里云百炼 text-embedding-v4（OpenAI-compatible）
# Kimi 当前模型列表未提供 Embedding 模型，因此代码/文档 RAG 使用独立向量服务。
REPOPILOT_EMBEDDING_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
REPOPILOT_EMBEDDING_API_KEY=
REPOPILOT_EMBEDDING_MODEL=text-embedding-v4
REPOPILOT_EMBEDDING_DIMENSIONS=1024

# 本地基础设施
REPOPILOT_QDRANT_URL=http://127.0.0.1:6333
REPOPILOT_STATE_DB_PATH=.repopilot/state.sqlite
